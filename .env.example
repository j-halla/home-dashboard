# Stationboard (Swiss public transport)
STATION_NAME=Zurich HB

# Philips Hue
HUE_API_KEY=your-hue-api-key
HUE_BRIDGE_ADDRESS=192.168.1.100

# Calendar (waste collection)
ZIP=8000

# WiFi
WIFI_SSID=MyWiFiNetwork
WIFI_PASSWORD=MyWiFiPassword

# Weather (Open-Meteo - no API key needed)
WEATHER_LATITUDE=47.37
WEATHER_LONGITUDE=8.54
